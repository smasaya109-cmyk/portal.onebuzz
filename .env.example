# =========================================================
# portal.onebuzz 環境変数テンプレート
# このファイルは値を空にしてコミットする。実際の値は .env.local に書く(Git管理しない)。
# NEXT_PUBLIC_ を付けてよいのは「公開してよい値」だけ。
# =========================================================

# --- Supabase(公開可: クライアントから使用) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase(非公開: サーバー側のみ。絶対に NEXT_PUBLIC_ を付けない) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend(非公開: サーバー側のみ) ---
RESEND_API_KEY=
# 問い合わせ通知の送信先(固定の自分のアドレス)
CONTACT_TO_EMAIL=

# --- サイト設定 ---
NEXT_PUBLIC_SITE_URL=https://portal.onebuzz
